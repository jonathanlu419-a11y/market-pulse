# ─── Earnings countdown data source (Finnhub) ─────────────────────────────────
# Finnhub API key — used by the /api/earnings feature ONLY. Free tier = 60
# calls/min (one /calendar/earnings call per 6h window covers the whole market).
# Get a key: https://finnhub.io  →  Sign up  →  Dashboard.
FINNHUB_API_KEY=

# ─── RSI alerts data source (Twelve Data) ─────────────────────────────────────
# Twelve Data API key — used by the /alerts RSI scan ONLY.
# Free "Basic" plan = 8 API credits/min, 800/day; /time_series costs 1 credit
# per symbol. Get a key: https://twelvedata.com  →  Sign up  →  Dashboard.
TWELVE_DATA_API_KEY=

# ─── RSI alerts cache (Render Postgres) ───────────────────────────────────────
# Connection string for the `market_pulse` database — a SEPARATE database within
# the same Render Postgres instance used by the finance-app (not shared tables).
# ⚠️ Use the POOLED (PgBouncer / "Pooler") connection string, NOT the direct one,
# to avoid exhausting Postgres connections under serverless. Render dashboard →
# Postgres instance → Connections → "Pooled connection".
MARKET_PULSE_DATABASE_URL=

# ─── Protects the daily cron route /api/cron/rsi-scan ─────────────────────────
# Any long random string. Vercel Cron sends it as `Authorization: Bearer <value>`.
CRON_SECRET=

# ─── Optional RSI-scan tuning ─────────────────────────────────────────────────
# Twelve Data free tier is 8 credits/min, so a large universe can't be scanned in
# one cron run. Set RSI_BATCH_COUNT ≈ ceil(universe / 6) to split across days by
# day-of-year (each run scans a rotating 1/N slice). On a paid Twelve Data plan
# with credits/min ≥ universe size, leave it at 1.
# RSI_BATCH_COUNT=1
# RSI_SCAN_DELAY_MS=7500   # ms between symbol fetches (default 7500 = 8/min)
