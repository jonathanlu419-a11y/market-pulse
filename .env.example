# ─── Required for earnings + RSI data ─────────────────────────────────────────
# Financial Modeling Prep API key.
# Get a key: https://financialmodelingprep.com  →  Sign up  →  Dashboard  →  API Keys
FMP_API_KEY=

# ─── Required for the /alerts RSI feature (Render Postgres) ───────────────────
# Connection string for the `market_pulse` database — a SEPARATE database within
# the same Render Postgres instance used by the finance-app (not shared tables).
# ⚠️ Use the POOLED (PgBouncer / "Pooler") connection string, NOT the direct one,
# to avoid exhausting Postgres connections under serverless. Render dashboard →
# Postgres instance → Connections → "Pooled connection".
MARKET_PULSE_DATABASE_URL=

# ─── Protects the daily cron route /api/cron/rsi-scan ─────────────────────────
# Any long random string. Vercel Cron sends it as `Authorization: Bearer <value>`.
CRON_SECRET=

# ─── Optional RSI-scan tuning ─────────────────────────────────────────────────
# FMP free tier = 250 calls/day, but the combined universe is ~517 tickers.
# Set RSI_BATCH_COUNT=3 to split the universe across days (~172 calls/run) and
# stay under the free-tier limit. Leave unset (=1) only on a paid FMP plan.
# RSI_BATCH_COUNT=3
# RSI_SCAN_DELAY_MS=150
